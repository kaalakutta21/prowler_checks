#!/usr/bin/env python3

import boto3
import argparse
import csv
from tqdm import tqdm
from botocore.exceptions import ClientError

# ==================================================
# AUTH
# ==================================================

def get_session(role_arn=None):
    if role_arn:
        base = boto3.Session()
        sts = base.client("sts")

        assumed = sts.assume_role(
            RoleArn=role_arn,
            RoleSessionName="s3-crr-audit"
        )

        creds = assumed["Credentials"]

        return boto3.Session(
            aws_access_key_id=creds["AccessKeyId"],
            aws_secret_access_key=creds["SecretAccessKey"],
            aws_session_token=creds["SessionToken"]
        )

    return boto3.Session()


def get_account_id(session):
    return session.client("sts").get_caller_identity()["Account"]


# ==================================================
# CONTROL LOGIC
# ==================================================

def check_s3_cross_region_replication(session):

    s3 = session.client("s3")

    try:
        buckets = s3.list_buckets()["Buckets"]
    except ClientError as e:
        print("Failed to list buckets:", e)
        return [], 0, 0, 0

    results = []
    non_compliant = 0
    total_checked = 0

    print(f"\nBuckets to Scan: {len(buckets)}\n")

    for bucket in tqdm(buckets, desc="Scanning Buckets"):

        bucket_name = bucket["Name"]

        try:
            location = s3.get_bucket_location(Bucket=bucket_name)
            source_region = location.get("LocationConstraint") or "us-east-1"

        except ClientError:
            continue

        replication_status = "Disabled"
        destination_region = "None"
        status = "NON_COMPLIANT"

        try:
            replication = s3.get_bucket_replication(Bucket=bucket_name)

            rules = replication["ReplicationConfiguration"]["Rules"]

            if rules:
                replication_status = "Enabled"

                destination_arn = rules[0]["Destination"]["Bucket"]

                dest_bucket = destination_arn.split(":::")[-1]

                dest_location = s3.get_bucket_location(Bucket=dest_bucket)

                destination_region = dest_location.get("LocationConstraint") or "us-east-1"

                if destination_region != source_region:
                    status = "COMPLIANT"
                else:
                    status = "NON_COMPLIANT"

        except ClientError as e:

            error_code = e.response["Error"]["Code"]

            if error_code in ["ReplicationConfigurationNotFoundError", "NoSuchReplicationConfiguration"]:
                status = "NON_COMPLIANT"
            else:
                continue

        total_checked += 1

        if status == "NON_COMPLIANT":
            non_compliant += 1

        results.append({
            "BucketName": bucket_name,
            "SourceRegion": source_region,
            "DestinationRegion": destination_region,
            "ReplicationStatus": replication_status,
            "Status": status
        })

    compliant = total_checked - non_compliant

    return results, total_checked, compliant, non_compliant


# ==================================================
# CSV OUTPUT
# ==================================================

def write_csv(account_id, results):

    filename = f"s3_cross_region_replication_{account_id}.csv"

    with open(filename, "w", newline="") as f:

        fields = [
            "Account",
            "BucketName",
            "SourceRegion",
            "DestinationRegion",
            "ReplicationStatus",
            "Status"
        ]

        writer = csv.DictWriter(f, fieldnames=fields)

        writer.writeheader()

        for r in results:
            writer.writerow({
                "Account": account_id,
                **r
            })

    return filename


# ==================================================
# MAIN
# ==================================================

def main():

    parser = argparse.ArgumentParser(
        description="Check if S3 buckets use cross region replication"
    )

    parser.add_argument("-R", "--role-arn", help="Role ARN to assume")

    args = parser.parse_args()

    session = get_session(args.role_arn)

    try:
        account_id = get_account_id(session)
    except Exception as e:
        print("Credential validation failed:", e)
        return

    results, total_checked, compliant, non_compliant = \
        check_s3_cross_region_replication(session)

    print("\n====================================================")
    print("CONTROL: S3 Buckets Use Cross Region Replication")
    print(f"ACCOUNT: {account_id}")
    print("====================================================")

    overall_status = "COMPLIANT" if non_compliant == 0 else "NON_COMPLIANT"

    print(f"OVERALL STATUS: {overall_status}\n")

    print("----------------------------------------------------")
    print(f"Total Buckets Checked : {total_checked}")
    print(f"Compliant             : {compliant}")
    print(f"Non-Compliant         : {non_compliant}")
    print("====================================================\n")

    csv_file = write_csv(account_id, results)

    print(f"CSV Report Generated: {csv_file}\n")


if __name__ == "__main__":
    main()
