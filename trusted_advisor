#!/usr/bin/env python3

import boto3
import argparse
import csv
from tqdm import tqdm
from botocore.exceptions import ClientError

# ==================================================
# AUTH
# ==================================================

def get_session(role_arn=None):

    if role_arn:
        base = boto3.Session()
        sts = base.client("sts")

        assumed = sts.assume_role(
            RoleArn=role_arn,
            RoleSessionName="trusted-advisor-audit"
        )

        creds = assumed["Credentials"]

        return boto3.Session(
            aws_access_key_id=creds["AccessKeyId"],
            aws_secret_access_key=creds["SecretAccessKey"],
            aws_session_token=creds["SessionToken"],
            region_name="us-east-1"
        )

    return boto3.Session(region_name="us-east-1")


def get_account_id(session):
    return session.client("sts").get_caller_identity()["Account"]


# ==================================================
# CONTROL LOGIC
# ==================================================

def check_trusted_advisor(session):

    results = []
    total_checked = 0
    non_compliant = 0

    account_id = get_account_id(session)

    try:
        support = session.client("support", region_name="us-east-1")
    except ClientError:
        print("Unable to access Trusted Advisor")
        return [], 0, 0, 0

    # ---------- GET CHECKS ----------
    try:
        checks = support.describe_trusted_advisor_checks(language="en")["checks"]
    except ClientError as e:

        if e.response["Error"]["Code"] == "SubscriptionRequiredException":
            print("\n❌ Trusted Advisor requires Business/Enterprise Support Plan\n")
            return [], 0, 0, 0

        raise

    print(f"\nTotal Trusted Advisor Checks: {len(checks)}\n")

    # ---------- PROCESS ----------
    for check in tqdm(checks, desc="Evaluating Checks"):

        check_id = check["id"]
        check_name = check["name"]
        category = check["category"]

        try:
            result = support.describe_trusted_advisor_check_result(
                checkId=check_id
            )["result"]

        except ClientError:
            continue

        ta_status = result.get("status", "ok")

        total_checked += 1

        final_status = "COMPLIANT"

        if ta_status in ["warning", "error"]:
            final_status = "NON_COMPLIANT"
            non_compliant += 1

        # ✅ Prowler-style ARN
        arn = f"arn:aws:trusted_advisor:us-east-1:{account_id}:check/{check_id}"

        results.append({
            "CheckId": check_id,
            "CheckArn": arn,
            "CheckName": check_name,
            "Category": category,
            "TAStatus": ta_status,
            "Status": final_status
        })


    compliant = total_checked - non_compliant

    return results, total_checked, compliant, non_compliant


# ==================================================
# CSV
# ==================================================

def write_csv(account_id, results):

    filename = f"trusted_advisor_{account_id}.csv"

    with open(filename, "w", newline="") as f:

        fields = [
            "Account",
            "CheckId",
            "CheckArn",
            "CheckName",
            "Category",
            "TAStatus",
            "Status"
        ]

        writer = csv.DictWriter(f, fieldnames=fields)

        writer.writeheader()

        for r in results:
            writer.writerow({
                "Account": account_id,
                **r
            })

    return filename


# ==================================================
# MAIN
# ==================================================

def main():

    parser = argparse.ArgumentParser(
        description="Check Trusted Advisor for warnings and errors"
    )

    parser.add_argument("-R","--role-arn",help="Role ARN to assume")

    args = parser.parse_args()

    session = get_session(args.role_arn)

    account_id = get_account_id(session)

    results,total_checked,compliant,non_compliant = \
        check_trusted_advisor(session)

    print("\n====================================================")
    print("CONTROL: Trusted Advisor Warnings and Errors")
    print(f"ACCOUNT: {account_id}")
    print("====================================================")

    overall = "COMPLIANT" if non_compliant == 0 else "NON_COMPLIANT"

    print(f"OVERALL STATUS: {overall}\n")

    print("----------------------------------------------------")
    print(f"Total Checks Evaluated : {total_checked}")
    print(f"Compliant              : {compliant}")
    print(f"Non-Compliant          : {non_compliant}")
    print("====================================================\n")

    if results:
        csv_file = write_csv(account_id,results)
        print(f"CSV Report Generated: {csv_file}\n")


if __name__ == "__main__":
    main()
