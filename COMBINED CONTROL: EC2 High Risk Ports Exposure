#!/usr/bin/env python3

import boto3
import argparse
import csv
from tqdm import tqdm

# ==================================================
# CONTROL MAP
# ==================================================

CONTROL_PORTS = {
"Ensure no EC2 instances allow ingress from the internet to Cassandra ports (TCP 7000, 7001, 7199, 9042, 9160).":[7000,7001,7199,9042,9160],
"Ensure no EC2 instances allow ingress from the internet to Elasticsearch and Kibana ports (TCP 9200, 9300, 5601).":[9200,9300,5601],
"Ensure no EC2 instances allow ingress from the internet to TCP port 11211 (Memcached).":[11211],
"Ensure no EC2 instances allow ingress from the internet to TCP port 139 or 445 (CIFS).":[139,445],
"Ensure no EC2 instances allow ingress from the internet to TCP port 1433 or 1434 (SQL Server).":[1433,1434],
"Ensure no EC2 instances allow ingress from the internet to TCP port 1521, 2483 or 2484 (Oracle).":[1521,2483,2484],
"Ensure no EC2 instances allow ingress from the internet to TCP port 20 or 21 (FTP)":[20,21],
"Ensure no EC2 instances allow ingress from the internet to TCP port 22 (SSH)":[22],
"Ensure no EC2 instances allow ingress from the internet to TCP port 23 (Telnet).":[23],
"Ensure no EC2 instances allow ingress from the internet to TCP port 27017 or 27018 (MongoDB)":[27017,27018],
"Ensure no EC2 instances allow ingress from the internet to TCP port 3306 (MySQL).":[3306],
"Ensure no EC2 instances allow ingress from the internet to TCP port 3389 (RDP)":[3389],
"Ensure no EC2 instances allow ingress from the internet to TCP port 389 or 636 (LDAP).":[389,636],
"Ensure no EC2 instances allow ingress from the internet to TCP port 5432 (PostgreSQL)":[5432],
"Ensure no EC2 instances allow ingress from the internet to TCP port 6379 (Redis).":[6379],
"Ensure no EC2 instances allow ingress from the internet to TCP port 88, 464, 749 or 750 (Kerberos).":[88,464,749,750],
"Ensure no EC2 instances allow ingress from the internet to TCP port 9092 (Kafka).":[9092]
}

# ==================================================
# HELPERS
# ==================================================

def get_regions(session):
    ec2 = session.client("ec2", region_name="us-east-1")
    return [r["RegionName"] for r in ec2.describe_regions(AllRegions=True)["Regions"]
            if r["OptInStatus"] in ["opt-in-not-required","opted-in"]]

def is_public(rule):
    for ip in rule.get("IpRanges", []):
        if ip.get("CidrIp") == "0.0.0.0/0":
            return True
    for ip in rule.get("Ipv6Ranges", []):
        if ip.get("CidrIpv6") == "::/0":
            return True
    return False

def matches_port(rule, port):
    proto = rule.get("IpProtocol")

    if proto == "-1":
        return True

    if proto != "tcp":
        return False

    fp = rule.get("FromPort")
    tp = rule.get("ToPort")

    if fp is None or tp is None:
        return False

    return fp <= port <= tp

# ==================================================
# MAIN LOGIC
# ==================================================

def scan(session):

    account = session.client("sts").get_caller_identity()["Account"]
    regions = get_regions(session)

    results = []
    total_instances = 0

    for region in tqdm(regions, desc="Regions"):

        ec2 = session.client("ec2", region_name=region)

        sg_map = {}
        for page in ec2.get_paginator("describe_security_groups").paginate():
            for sg in page["SecurityGroups"]:
                sg_map[sg["GroupId"]] = sg

        for page in ec2.get_paginator("describe_instances").paginate():

            for res in page["Reservations"]:
                for inst in res["Instances"]:

                    total_instances += 1

                    instance_id = inst["InstanceId"]
                    arn = f"arn:aws:ec2:{region}:{account}:instance/{instance_id}"

                    # Collect SGs from ENIs
                    sg_ids = []
                    for eni in inst.get("NetworkInterfaces", []):
                        for g in eni.get("Groups", []):
                            sg_ids.append(g["GroupId"])

                    instance_findings = {control: False for control in CONTROL_PORTS}

                    # Evaluate rules
                    for sg_id in sg_ids:

                        sg = sg_map.get(sg_id)
                        if not sg:
                            continue

                        for rule in sg.get("IpPermissions", []):

                            if not is_public(rule):
                                continue

                            for control, ports in CONTROL_PORTS.items():
                                for port in ports:
                                    if matches_port(rule, port):
                                        instance_findings[control] = True

                    # Final result per control
                    for control in CONTROL_PORTS:

                        status = "NON_COMPLIANT" if instance_findings[control] else "COMPLIANT"

                        results.append({
                            "Region": region,
                            "InstanceId": instance_id,
                            "InstanceArn": arn,
                            "Control": control,
                            "Status": status
                        })

    return results, total_instances


# ==================================================
# CSV
# ==================================================

def write_csv(account, results):

    file = f"final_all_instances_sg_audit_{account}.csv"

    with open(file, "w", newline="") as f:

        writer = csv.DictWriter(f, fieldnames=[
            "Account","Region","InstanceId","InstanceArn","Control","Status"
        ])

        writer.writeheader()

        for r in results:
            writer.writerow({"Account": account, **r})

    return file


# ==================================================
# MAIN
# ==================================================

def main():

    parser = argparse.ArgumentParser()
    parser.add_argument("-R","--role-arn")
    args = parser.parse_args()

    session = boto3.Session()

    if args.role_arn:
        sts = session.client("sts")
        creds = sts.assume_role(
            RoleArn=args.role_arn,
            RoleSessionName="sg-final"
        )["Credentials"]

        session = boto3.Session(
            aws_access_key_id=creds["AccessKeyId"],
            aws_secret_access_key=creds["SecretAccessKey"],
            aws_session_token=creds["SessionToken"]
        )

    account = session.client("sts").get_caller_identity()["Account"]

    results, total_instances = scan(session)

    print("\n====================================================")
    print(f"ACCOUNT: {account}")
    print("====================================================")
    print(f"Total Instances: {total_instances}")
    print(f"Total Rows: {len(results)}")

    csv_file = write_csv(account, results)

    print(f"\nCSV Generated: {csv_file}\n")


if __name__ == "__main__":
    main()
