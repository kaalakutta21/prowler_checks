#!/usr/bin/env python3

import boto3
import argparse
import csv
from tqdm import tqdm

# ==================================================
# AUTH
# ==================================================

def get_session(role_arn=None):
    if role_arn:
        sts = boto3.client("sts")
        creds = sts.assume_role(
            RoleArn=role_arn,
            RoleSessionName="ec2-all-ports-final"
        )["Credentials"]

        return boto3.Session(
            aws_access_key_id=creds["AccessKeyId"],
            aws_secret_access_key=creds["SecretAccessKey"],
            aws_session_token=creds["SessionToken"]
        )
    return boto3.Session()


def get_account_id(session):
    return session.client("sts").get_caller_identity()["Account"]


# ==================================================
# REGIONS
# ==================================================

def get_regions(session):
    ec2 = session.client("ec2", region_name="us-east-1")
    return [
        r["RegionName"]
        for r in ec2.describe_regions(AllRegions=True)["Regions"]
        if r["OptInStatus"] in ["opt-in-not-required", "opted-in"]
    ]


# ==================================================
# HELPERS
# ==================================================

def is_public(rule):
    for ip in rule.get("IpRanges", []):
        if ip.get("CidrIp") == "0.0.0.0/0":
            return True

    for ip in rule.get("Ipv6Ranges", []):
        if ip.get("CidrIpv6") == "::/0":
            return True

    return False


def is_all_ports(rule):
    proto = rule.get("IpProtocol")
    from_port = rule.get("FromPort")
    to_port = rule.get("ToPort")

    if proto == "-1" and from_port is None and to_port is None:
        return True

    if proto == "tcp" and from_port == 0 and to_port == 65535:
        return True

    return False


# ==================================================
# MAIN LOGIC
# ==================================================

def check_all_ports(session):

    regions = get_regions(session)
    account_id = get_account_id(session)

    results = []
    total_instances = 0
    non_compliant_count = 0

    print(f"\nRegions to Scan: {len(regions)}\n")

    for region in tqdm(regions, desc="Scanning Regions"):

        ec2 = session.client("ec2", region_name=region)

        # Load SGs
        sg_map = {}
        for page in ec2.get_paginator("describe_security_groups").paginate():
            for sg in page["SecurityGroups"]:
                sg_map[sg["GroupId"]] = sg

        # Load instances
        instances = []
        for page in ec2.get_paginator("describe_instances").paginate():
            for res in page.get("Reservations", []):
                for inst in res.get("Instances", []):
                    instances.append(inst)

        print(f"{region} → Instances: {len(instances)}")

        for inst in instances:

            total_instances += 1

            instance_id = inst["InstanceId"]
            arn = f"arn:aws:ec2:{region}:{account_id}:instance/{instance_id}"

            sg_ids = set()

            # ENI SGs
            for eni in inst.get("NetworkInterfaces", []):
                for g in eni.get("Groups", []):
                    sg_ids.add(g["GroupId"])

            # fallback
            for g in inst.get("SecurityGroups", []):
                sg_ids.add(g["GroupId"])

            instance_status = "COMPLIANT"
            evidence = ""

            for sg_id in sg_ids:

                sg = sg_map.get(sg_id)
                if not sg:
                    continue

                for rule in sg.get("IpPermissions", []):

                    if not is_public(rule):
                        continue

                    if not is_all_ports(rule):
                        continue

                    # NON-COMPLIANT found
                    instance_status = "NON_COMPLIANT"
                    non_compliant_count += 1

                    evidence = f"SG {sg_id} allows ALL ports to internet"

                    break

                if instance_status == "NON_COMPLIANT":
                    break

            results.append({
                "Region": region,
                "InstanceId": instance_id,
                "InstanceArn": arn,
                "Status": instance_status,
                "Evidence": evidence if evidence else "No public all-port exposure"
            })

    return results, total_instances, non_compliant_count


# ==================================================
# CSV
# ==================================================

def write_csv(account_id, results):

    filename = f"ec2_all_ports_with_compliance_{account_id}.csv"

    with open(filename, "w", newline="") as f:

        writer = csv.DictWriter(f, fieldnames=[
            "Account",
            "Region",
            "InstanceId",
            "InstanceArn",
            "Status",
            "Evidence"
        ])

        writer.writeheader()

        for r in results:
            writer.writerow({
                "Account": account_id,
                **r
            })

    return filename


# ==================================================
# MAIN
# ==================================================

def main():

    parser = argparse.ArgumentParser(
        description="EC2 ALL PORTS exposure check with COMPLIANT + NON-COMPLIANT"
    )

    parser.add_argument("-R", "--role-arn")
    args = parser.parse_args()

    session = get_session(args.role_arn)
    account_id = get_account_id(session)

    results, total_instances, non_compliant = check_all_ports(session)

    compliant = total_instances - non_compliant

    print("\n====================================================")
    print("CONTROL: EC2 ALL PORTS EXPOSURE (FINAL)")
    print(f"ACCOUNT: {account_id}")
    print("====================================================\n")

    print(f"Total Instances Checked : {total_instances}")
    print(f"Compliant               : {compliant}")
    print(f"Non-Compliant           : {non_compliant}")

    overall = "COMPLIANT" if non_compliant == 0 else "NON_COMPLIANT"

    print(f"\nOVERALL STATUS: {overall}")
    print("====================================================\n")

    csv_file = write_csv(account_id, results)

    print(f"CSV Generated: {csv_file}\n")


if __name__ == "__main__":
    main()
