#!/usr/bin/env python3

import boto3
import argparse
import csv
from tqdm import tqdm
from botocore.exceptions import ClientError

# ==================================================
# AUTH
# ==================================================

def get_session(role_arn=None):

    if role_arn:
        base = boto3.Session()
        sts = base.client("sts")

        assumed = sts.assume_role(
            RoleArn=role_arn,
            RoleSessionName="ec2-all-ports-audit"
        )

        creds = assumed["Credentials"]

        return boto3.Session(
            aws_access_key_id=creds["AccessKeyId"],
            aws_secret_access_key=creds["SecretAccessKey"],
            aws_session_token=creds["SessionToken"]
        )

    return boto3.Session()


def get_account_id(session):
    return session.client("sts").get_caller_identity()["Account"]


# ==================================================
# REGIONS
# ==================================================

def get_regions(session):

    ec2 = session.client("ec2", region_name="us-east-1")

    regions = ec2.describe_regions(AllRegions=True)["Regions"]

    return [
        r["RegionName"]
        for r in regions
        if r.get("OptInStatus") in ["opt-in-not-required", "opted-in"]
    ]


# ==================================================
# HELPERS
# ==================================================

def is_public(rule):

    for ip in rule.get("IpRanges", []):
        if ip.get("CidrIp") == "0.0.0.0/0":
            return True

    for ip in rule.get("Ipv6Ranges", []):
        if ip.get("CidrIpv6") == "::/0":
            return True

    return False


def is_all_ports(rule):

    proto = rule.get("IpProtocol")
    from_port = rule.get("FromPort")
    to_port = rule.get("ToPort")

    # Case 1: ALL protocols → all ports
    if proto == "-1":
        return True

    # Case 2: Full TCP range
    if proto == "tcp":
        if from_port == 0 and to_port == 65535:
            return True

    return False


# ==================================================
# SAFE INSTANCE FETCH
# ==================================================

def get_all_instances(ec2):

    instances = []

    paginator = ec2.get_paginator("describe_instances")

    for page in paginator.paginate():

        for res in page.get("Reservations", []):
            for inst in res.get("Instances", []):
                instances.append(inst)

    return instances


# ==================================================
# CONTROL LOGIC
# ==================================================

def check_ec2_all_ports(session):

    regions = get_regions(session)

    results = []
    total_instances = 0
    findings = 0
    skipped_regions = 0

    account_id = get_account_id(session)

    print(f"\nRegions to Scan: {len(regions)}\n")

    for region in tqdm(regions, desc="Scanning Regions"):

        try:
            ec2 = session.client("ec2", region_name=region)

        except ClientError:
            skipped_regions += 1
            continue

        # Load SGs
        sg_map = {}
        for page in ec2.get_paginator("describe_security_groups").paginate():
            for sg in page.get("SecurityGroups", []):
                sg_map[sg["GroupId"]] = sg

        instances = get_all_instances(ec2)

        print(f"{region} → Instances: {len(instances)}")

        for inst in instances:

            total_instances += 1

            instance_id = inst["InstanceId"]
            arn = f"arn:aws:ec2:{region}:{account_id}:instance/{instance_id}"

            # SG extraction (ENI + fallback)
            sg_ids = []

            for eni in inst.get("NetworkInterfaces", []):
                for g in eni.get("Groups", []):
                    sg_ids.append(g["GroupId"])

            for g in inst.get("SecurityGroups", []):
                sg_ids.append(g["GroupId"])

            for sg_id in sg_ids:

                sg = sg_map.get(sg_id)
                if not sg:
                    continue

                for rule in sg.get("IpPermissions", []):

                    # Must be public
                    if not is_public(rule):
                        continue

                    # Must be ALL PORTS
                    if not is_all_ports(rule):
                        continue

                    findings += 1

                    results.append({
                        "Region": region,
                        "InstanceId": instance_id,
                        "InstanceArn": arn,
                        "SecurityGroupId": sg_id,
                        "RuleProtocol": rule.get("IpProtocol"),
                        "FromPort": rule.get("FromPort"),
                        "ToPort": rule.get("ToPort"),
                        "Status": "NON_COMPLIANT",
                        "Reason": "Public access to ALL ports"
                    })

    return results, total_instances, findings, skipped_regions


# ==================================================
# CSV
# ==================================================

def write_csv(account_id, results):

    filename = f"ec2_all_ports_exposure_{account_id}.csv"

    with open(filename, "w", newline="") as f:

        fields = [
            "Account",
            "Region",
            "InstanceId",
            "InstanceArn",
            "SecurityGroupId",
            "RuleProtocol",
            "FromPort",
            "ToPort",
            "Status",
            "Reason"
        ]

        writer = csv.DictWriter(f, fieldnames=fields)
        writer.writeheader()

        for r in results:
            writer.writerow({
                "Account": account_id,
                **r
            })

    return filename


# ==================================================
# MAIN
# ==================================================

def main():

    parser = argparse.ArgumentParser(
        description="Ensure no EC2 instances allow ingress from internet to ALL ports"
    )

    parser.add_argument("-R", "--role-arn", help="Role ARN")

    args = parser.parse_args()

    session = get_session(args.role_arn)
    account_id = get_account_id(session)

    results, total_instances, findings, skipped_regions = \
        check_ec2_all_ports(session)

    print("\n====================================================")
    print("CONTROL: EC2 All Ports Exposure")
    print(f"ACCOUNT: {account_id}")
    print("====================================================\n")

    print(f"Total Instances Checked : {total_instances}")
    print(f"Findings (Non-Compliant): {findings}")
    print(f"Skipped Regions         : {skipped_regions}")

    overall = "COMPLIANT" if findings == 0 else "NON_COMPLIANT"

    print(f"\nOVERALL STATUS: {overall}")
    print("====================================================\n")

    csv_file = write_csv(account_id, results)

    print(f"CSV Report Generated: {csv_file}\n")


if __name__ == "__main__":
    main()
