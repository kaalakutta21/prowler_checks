#!/usr/bin/env python3

import boto3
import argparse
import csv
from tqdm import tqdm
from botocore.exceptions import ClientError

# ==================================================
# CONTROL → PORT MAPPING (EXACT NAMES)
# ==================================================

CONTROL_PORTS = {

"Ensure no EC2 instances allow ingress from the internet to Cassandra ports (TCP 7000, 7001, 7199, 9042, 9160).":
    [7000,7001,7199,9042,9160],

"Ensure no EC2 instances allow ingress from the internet to Elasticsearch and Kibana ports (TCP 9200, 9300, 5601).":
    [9200,9300,5601],

"Ensure no EC2 instances allow ingress from the internet to TCP port 11211 (Memcached).":
    [11211],

"Ensure no EC2 instances allow ingress from the internet to TCP port 139 or 445 (CIFS).":
    [139,445],

"Ensure no EC2 instances allow ingress from the internet to TCP port 1433 or 1434 (SQL Server).":
    [1433,1434],

"Ensure no EC2 instances allow ingress from the internet to TCP port 1521, 2483 or 2484 (Oracle).":
    [1521,2483,2484],

"Ensure no EC2 instances allow ingress from the internet to TCP port 20 or 21 (FTP)":
    [20,21],

"Ensure no EC2 instances allow ingress from the internet to TCP port 22 (SSH)":
    [22],

"Ensure no EC2 instances allow ingress from the internet to TCP port 23 (Telnet).":
