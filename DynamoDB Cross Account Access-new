#!/usr/bin/env python3

import boto3
import argparse
import csv
import json
from tqdm import tqdm
from botocore.exceptions import ClientError

# ==================================================
# AUTH
# ==================================================

def get_session(role_arn=None):
    if role_arn:
        base = boto3.Session()
        sts = base.client("sts")

        assumed = sts.assume_role(
            RoleArn=role_arn,
            RoleSessionName="dynamodb-cross-account-audit"
        )

        creds = assumed["Credentials"]

        return boto3.Session(
            aws_access_key_id=creds["AccessKeyId"],
            aws_secret_access_key=creds["SecretAccessKey"],
            aws_session_token=creds["SessionToken"]
        )

    return boto3.Session()


def get_account_id(session):
    return session.client("sts").get_caller_identity()["Account"]


# ==================================================
# REGIONS
# ==================================================

def get_regions(session):
    ec2 = session.client("ec2", region_name="us-east-1")

    regions = ec2.describe_regions(AllRegions=True)["Regions"]

    return [
        r["RegionName"]
        for r in regions
        if r.get("OptInStatus") in ["opt-in-not-required", "opted-in"]
    ]


# ==================================================
# POLICY CHECK
# ==================================================

def analyze_policy(policy_str, account_id):

    try:
        policy = json.loads(policy_str)
    except Exception:
        return False, "Invalid policy JSON"

    statements = policy.get("Statement", [])

    if isinstance(statements, dict):
        statements = [statements]

    for stmt in statements:

        if stmt.get("Effect") != "Allow":
            continue

        principal = stmt.get("Principal")

        if principal == "*":
            return True, "Public access (*)"

        if isinstance(principal, dict):

            aws = principal.get("AWS")

            if isinstance(aws, str):
                if account_id not in aws:
                    return True, f"Cross-account: {aws}"

            elif isinstance(aws, list):
                for p in aws:
                    if account_id not in p:
                        return True, f"Cross-account: {p}"

    return False, "No cross-account access"


# ==================================================
# CONTROL LOGIC
# ==================================================

def check_dynamodb_cross_account(session):

    regions = get_regions(session)

    results = []
    total = 0
    non_compliant = 0
    skipped = 0

    account_id = get_account_id(session)

    # 🔹 Check if API exists
    dynamodb = session.client("dynamodb")

    has_policy_api = hasattr(dynamodb, "get_resource_policy")

    print(f"\nResource Policy API Available: {has_policy_api}\n")

    for region in tqdm(regions, desc="Scanning Regions"):

        try:
            dynamodb = session.client("dynamodb", region_name=region)
            paginator = dynamodb.get_paginator("list_tables")

        except ClientError:
            continue

        for page in paginator.paginate():

            for table_name in page.get("TableNames", []):

                arn = f"arn:aws:dynamodb:{region}:{account_id}:table/{table_name}"

                total += 1

                # ==================================================
                # CASE 1: API NOT AVAILABLE
                # ==================================================
                if not has_policy_api:

                    results.append({
                        "Region": region,
                        "TableName": table_name,
                        "TableArn": arn,
                        "Status": "UNKNOWN",
                        "Reason": "boto3 does not support get_resource_policy"
                    })

                    continue

                # ==================================================
                # CASE 2: API AVAILABLE
                # ==================================================
                try:
                    resp = dynamodb.get_resource_policy(
                        ResourceArn=arn
                    )

                    policy = resp.get("Policy")

                except ClientError as e:

                    code = e.response["Error"]["Code"]

                    if code in ["PolicyNotFoundException", "ResourceNotFoundException"]:
                        results.append({
                            "Region": region,
                            "TableName": table_name,
                            "TableArn": arn,
                            "Status": "COMPLIANT",
                            "Reason": "No resource policy"
                        })
                        continue

                    else:
                        skipped += 1
                        continue

                is_bad, reason = analyze_policy(policy, account_id)

                if is_bad:
                    status = "NON_COMPLIANT"
                    non_compliant += 1
                else:
                    status = "COMPLIANT"

                results.append({
                    "Region": region,
                    "TableName": table_name,
                    "TableArn": arn,
                    "Status": status,
                    "Reason": reason
                })

    compliant = total - non_compliant

    return results, total, compliant, non_compliant, skipped


# ==================================================
# CSV
# ==================================================

def write_csv(account_id, results):

    filename = f"dynamodb_cross_account_{account_id}.csv"

    with open(filename, "w", newline="") as f:

        fields = [
            "Account",
            "Region",
            "TableName",
            "TableArn",
            "Status",
            "Reason"
        ]

        writer = csv.DictWriter(f, fieldnames=fields)
        writer.writeheader()

        for r in results:
            writer.writerow({
                "Account": account_id,
                **r
            })

    return filename


# ==================================================
# MAIN
# ==================================================

def main():

    parser = argparse.ArgumentParser(
        description="DynamoDB cross-account access check (robust)"
    )

    parser.add_argument("-R", "--role-arn", help="Role ARN")

    args = parser.parse_args()

    session = get_session(args.role_arn)
    account_id = get_account_id(session)

    results, total, compliant, non_compliant, skipped = \
        check_dynamodb_cross_account(session)

    print("\n====================================================")
    print("CONTROL: DynamoDB Cross Account Access")
    print(f"ACCOUNT: {account_id}")
    print("====================================================\n")

    print(f"Total Tables Checked : {total}")
    print(f"Compliant            : {compliant}")
    print(f"Non-Compliant        : {non_compliant}")
    print(f"Skipped              : {skipped}")

    csv_file = write_csv(account_id, results)

    print(f"\nCSV Report Generated: {csv_file}\n")


if __name__ == "__main__":
    main()
