# =========================================================
# ARGUMENTS
# =========================================================
def parse_args():
    parser = argparse.ArgumentParser(
        description="Audit AWS cross-region effective access, SCP clues, and read-only regional permissions."
    )
    parser.add_argument(
        "-R", "--role-arn",
        help="Optional role ARN to assume."
    )
    parser.add_argument(
        "--external-id",
        help="Optional external ID for assume-role."
    )
    parser.add_argument(
        "--profile",
        help="Optional AWS CLI profile."
    )
    parser.add_argument(
        "--region",
        default="ap-south-1",
        help="Base region for control plane calls. Default: ap-south-1"
    )
    parser.add_argument(
        "--outdir",
        default="region_access_audit_output",
        help="Output directory for reports."
    )
    parser.add_argument(
        "--workers",
        type=int,
        default=10,
        help="Number of parallel workers. Default: 10"
    )
    parser.add_argument(
        "--mode",
        choices=["fast", "full"],
        default="fast",
        help="fast = ec2/lambda/rds only, full = add dynamodb/ecs/eks"
    )
    parser.add_argument(
        "--regions",
        nargs="*",
        help="Optional explicit region list to test. Example: --regions ap-south-1 us-east-1 eu-west-1"
    )
    parser.add_argument(
        "--enabled-regions-only",
        action="store_true",
        default=True,
        help="Test only enabled regions (opted-in / opt-in-not-required). Default behavior."
    )
    parser.add_argument(
        "--include-disabled-regions",
        action="store_true",
        help="Also include disabled regions in testing."
    )
    parser.add_argument(
        "--no-color",
        action="store_true",
        help="Disable terminal colors."
    )
    return parser.parse_args()


ARGS = parse_args()

if ARGS.no_color:
