    lines.append(", ".join([f"{r['RegionName']}({r['OptInStatus']})" for r in regions]))
    lines.append("")
    lines.append("PER-REGION SUMMARY")
    lines.append("-" * 100)
    for rr in region_results:
        s = rr["summary"]
        lines.append(
            f"{rr['region']}: Allowed={s['allowed']}, SCP={s['scp_deny']}, "
            f"IAM={s['iam_or_session_deny'] + s['permission_boundary_deny'] + s['session_policy_deny']}, "
