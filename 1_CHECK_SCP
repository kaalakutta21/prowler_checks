# =========================================================
# MAIN
# =========================================================
def main():
    ensure_dir(ARGS.outdir)
    ts = iso_now()
    session = get_session()

    print_section("AWS REGION / SCP / EFFECTIVE ACCESS AUDIT")

    print(c("Starting audit...", CYAN))
    if ARGS.role_arn:
        print(f"Assume role requested: {c(ARGS.role_arn, YELLOW)}")

    identity = get_identity(session)

    print_section("CURRENT IDENTITY")
    print(f"Account ID      : {c(identity['account_id'], GREEN)}")
    print(f"ARN             : {c(identity['arn'], GREEN)}")
    print(f"Principal Type  : {c(identity['principal_type'], YELLOW)}")
    print(f"Assumed Role    : {yes_no(identity['assumed_role'])}")
    print(f"Role Name       : {identity.get('role_name')}")
    print(f"User Name       : {identity.get('user_name')}")
    print(f"Session Name    : {identity.get('session_name')}")

    iam_info = inspect_iam(session, identity)
    scp_info = inspect_scp(session, identity["account_id"])
    regions = get_all_regions(session)
    region_results = audit_regions(session, regions)
    findings = derive_findings(identity, iam_info, scp_info, region_results)

    print_section("IAM / SCP CLUES")
    print(f"IAM metadata visible          : {yes_no(iam_info['visibility'])}")
    print(f"ReadOnlyAccess attached       : {yes_no(iam_info['readonlyaccess_attached'])}")
    print(f"Organizations accessible      : {yes_no(scp_info['organizations_accessible'])}")
    print(f"SCP region restriction found  : {yes_no(scp_info['region_restriction_detected'])}")

    if iam_info["managed_policies"]:
        print("Managed policies visible:")
        for p in iam_info["managed_policies"]:
            print(f"  - {p.get('PolicyName')} ({p.get('PolicyArn')})")

    if iam_info["permission_boundary"]:
        print(f"Permission boundary: {iam_info['permission_boundary']}")

    if scp_info["scp_attached"]:
        print("Attached SCPs:")
        for p in scp_info["scp_attached"]:
            print(f"  - {p.get('Name')} ({p.get('Id')})")

    if scp_info["region_restriction_clues"]:
        print("\nSCP clues:")
        for clue in scp_info["region_restriction_clues"]:
            print(f"  {c(clue['policy_name'], YELLOW)}")
            for x in clue["clues"]:
                print(f"    - {x}")

    print_section("TOP CONCLUSION")
    print(f"Any access outside India           : {yes_no(findings['outside_india_any_access'])}")
    print(f"All regions full read-only access  : {yes_no(findings['all_regions_full_read_access'])}")

    if findings["regions_with_any_access_outside_india"]:
        print(f"Outside-India regions with some real access: {c(', '.join(findings['regions_with_any_access_outside_india']), YELLOW)}")
    else:
        print("Outside-India regions with some real access: None")

    if findings["possible_temporary_access_clues"]:
        print("\nWhy temporary access may still be working:")
        for item in findings["possible_temporary_access_clues"]:
            print(f"  - {item}")

    print_section("PER-REGION SUMMARY")
    for rr in region_results:
        print(terminal_region_line(rr))

    print_section("DETAILED FAILURES ONLY")
    any_failure = False
    for rr in region_results:
        failures = [x for x in rr["service_results"] if x["classification"] != "ALLOWED"]
        if failures:
            any_failure = True
            print(c(f"[{rr['region']}]", BOLD + MAGENTA))
            for sr in failures:
                print(
                    f"  {sr['service']:<10} {sr['action']:<28} "
                    f"{c(sr['classification'], RED if 'DENY' in sr['classification'] else YELLOW)} "
                    f"| {sr['error']}"
                )
    if not any_failure:
        print(c("No failures detected in tested read-only service probes.", GREEN))

    report_data = {
        "identity": identity,
        "iam_info": iam_info,
        "scp_info": scp_info,
        "regions": regions,
        "region_results": region_results,
        "findings": findings,
        "script_args": {
            "role_arn": ARGS.role_arn,
            "profile": ARGS.profile,
            "region": ARGS.region,
            "outdir": ARGS.outdir
        },
        "generated_at_utc": ts
    }

    json_path = os.path.join(ARGS.outdir, f"audit_report_{ts}.json")
    txt_path = os.path.join(ARGS.outdir, f"audit_report_{ts}.txt")
    scp_path = os.path.join(ARGS.outdir, f"scp_dump_{ts}.json")

    write_json(json_path, report_data)
    write_text(txt_path, build_text_report(identity, iam_info, scp_info, regions, region_results, findings))
    write_json(scp_path, scp_info)

    print_section("FILES GENERATED")
    print(f"JSON report : {c(json_path, GREEN)}")
    print(f"Text report : {c(txt_path, GREEN)}")
    print(f"SCP dump    : {c(scp_path, GREEN)}")

    print_section("FINAL INTERPRETATION GUIDE")
    print("Use the result like this:")
    print(f"  - {c('FULL_READ_OK', GREEN)}        -> tested read/list APIs worked in that region")
    print(f"  - {c('PARTIAL_ACCESS', YELLOW)}     -> some services work, some are blocked")
    print(f"  - {c('BLOCKED_BY_SCP', RED)}       -> tested services appear blocked by SCP")
    print(f"  - {c('IAM_OR_SESSION_DENY', RED)}  -> blocked by role/user/session policy or no permission")
    print(f"  - {c('REGION_NOT_ENABLED', MAGENTA)} -> account not opted into that region")
    print("")
    print("If SCP is active but non-India regions still show ALLOWED or PARTIAL_ACCESS,")
    print("then access is likely happening because of SCP exceptions, NotAction logic,")
    print("or because only some actions/services are blocked while read/list calls are still allowed.")


