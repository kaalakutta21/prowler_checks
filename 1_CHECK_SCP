# =========================================================
# HELPERS
# =========================================================
def ensure_dir(path):
    os.makedirs(path, exist_ok=True)


def iso_now():
    return datetime.utcnow().strftime("%Y-%m-%dT%H-%M-%SZ")


def write_json(path, data):
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, default=str)


def write_text(path, text):
    with open(path, "w", encoding="utf-8") as f:
        f.write(text)


def print_section(title):
    print("\n" + c("=" * 100, BLUE))
    print(c(title, BOLD + CYAN))
    print(c("=" * 100, BLUE))


def yes_no(v):
    return c("YES", GREEN) if v else c("NO", RED)


def safe_client(session, service, region_name=None):
    return session.client(service, region_name=region_name or ARGS.region)


def short_error(err):
    code = err.response.get("Error", {}).get("Code", "Unknown")
    msg = err.response.get("Error", {}).get("Message", "") or str(err)
    return f"{code}: {msg}"


def classify_error(err):
    code = err.response.get("Error", {}).get("Code", "Unknown")
    msg = err.response.get("Error", {}).get("Message", "") or str(err)
    full = f"{code}: {msg}".lower()

    if "service control policy" in full:
        return "SCP_DENY"
    if code in ("OptInRequired",) or "not subscribed to this region" in full:
        return "REGION_NOT_ENABLED"
    if "permissions boundary" in full:
        return "PERMISSION_BOUNDARY_DENY"
    if "session policy" in full:
        return "SESSION_POLICY_DENY"
    if (
        code in ("AccessDenied", "AccessDeniedException", "UnauthorizedOperation", "Client.UnauthorizedOperation")
        or "not authorized" in full
        or "accessdenied" in full
    ):
        return "IAM_OR_SESSION_DENY"
    if code in ("UnrecognizedClientException", "InvalidClientTokenId", "ExpiredToken"):
        return "CREDENTIAL_ISSUE"
    if code in ("RequestLimitExceeded", "Throttling", "ThrottlingException", "TooManyRequestsException"):
        return "THROTTLED"
    return "OTHER_ERROR"


# =========================================================
# SESSION
# =========================================================
def get_base_session(profile=None, region_name="ap-south-1"):
    if profile:
        return boto3.Session(profile_name=profile, region_name=region_name)
    return boto3.Session(region_name=region_name)


def assume_role(session, role_arn, external_id=None):
    sts = session.client("sts")
    kwargs = {
        "RoleArn": role_arn,
        "RoleSessionName": "region-access-audit-session"
    }
    if external_id:
        kwargs["ExternalId"] = external_id

    resp = sts.assume_role(**kwargs)
    creds = resp["Credentials"]

    return boto3.Session(
        aws_access_key_id=creds["AccessKeyId"],
        aws_secret_access_key=creds["SecretAccessKey"],
        aws_session_token=creds["SessionToken"],
        region_name=ARGS.region
    )


def get_session():
    base = get_base_session(ARGS.profile, ARGS.region)
    if ARGS.role_arn:
        return assume_role(base, ARGS.role_arn, ARGS.external_id)
    return base


# =========================================================
# IDENTITY
# =========================================================
def get_identity(session):
    sts = safe_client(session, "sts")
    resp = sts.get_caller_identity()

    arn = resp.get("Arn", "")
    account = resp.get("Account", "")
    user_id = resp.get("UserId", "")

    out = {
        "account_id": account,
        "arn": arn,
        "user_id": user_id,
        "principal_type": "unknown",
        "assumed_role": False,
        "role_name": None,
        "user_name": None,
        "session_name": None
    }

    if ":assumed-role/" in arn:
        out["principal_type"] = "assumed-role"
        out["assumed_role"] = True
        m = re.search(r"assumed-role/([^/]+)/(.+)$", arn)
        if m:
            out["role_name"] = m.group(1)
            out["session_name"] = m.group(2)
    elif ":user/" in arn:
        out["principal_type"] = "user"
        out["user_name"] = arn.split("/")[-1]
    elif ":role/" in arn:
        out["principal_type"] = "role"
        out["role_name"] = arn.split("/")[-1]

    return out


# =========================================================
# IAM CLUES
# =========================================================
def inspect_iam(session, identity):
    out = {
        "visibility": True,
        "managed_policies": [],
        "inline_policies": [],
        "permission_boundary": None,
        "readonlyaccess_attached": False,
        "errors": []
    }

    iam = safe_client(session, "iam")

    try:
        if identity["principal_type"] == "user" and identity["user_name"]:
            uname = identity["user_name"]

            user = iam.get_user(UserName=uname)["User"]
            out["permission_boundary"] = user.get("PermissionsBoundary")

            paginator = iam.get_paginator("list_attached_user_policies")
            for page in paginator.paginate(UserName=uname):
                out["managed_policies"].extend(page.get("AttachedPolicies", []))

            paginator = iam.get_paginator("list_user_policies")
            for page in paginator.paginate(UserName=uname):
                out["inline_policies"].extend(page.get("PolicyNames", []))

        elif identity["role_name"]:
            rname = identity["role_name"]

            role = iam.get_role(RoleName=rname)["Role"]
            out["permission_boundary"] = role.get("PermissionsBoundary")

            paginator = iam.get_paginator("list_attached_role_policies")
            for page in paginator.paginate(RoleName=rname):
                out["managed_policies"].extend(page.get("AttachedPolicies", []))

            paginator = iam.get_paginator("list_role_policies")
            for page in paginator.paginate(RoleName=rname):
                out["inline_policies"].extend(page.get("PolicyNames", []))

        for p in out["managed_policies"]:
            if p.get("PolicyName") == "ReadOnlyAccess" or p.get("PolicyArn", "").endswith(":policy/ReadOnlyAccess"):
                out["readonlyaccess_attached"] = True

    except botocore.exceptions.ClientError as e:
        out["visibility"] = False
        out["errors"].append(short_error(e))

    return out


# =========================================================
# SCP CLUES
# =========================================================
def analyze_scp_content(content):
    detected = False
    clues = []

    try:
        doc = json.loads(content) if isinstance(content, str) else content
        statements = doc.get("Statement", [])
        if isinstance(statements, dict):
            statements = [statements]

        for stmt in statements:
            stmt_text = json.dumps(stmt).lower()

            if "aws:requestedregion" in stmt_text:
                detected = True
                clues.append("Contains aws:RequestedRegion condition")
            if stmt.get("Effect") == "Deny":
                clues.append("Contains Deny statement")
            if "notaction" in stmt_text:
                clues.append("Uses NotAction (possible partial bypass / exception)")
            if "arnnotlike" in stmt_text or "stringnotequals" in stmt_text or "stringequals" in stmt_text:
                clues.append("Contains conditional exception logic")

    except Exception as e:
        clues.append(f"Could not parse SCP JSON: {e}")

    return detected, list(dict.fromkeys(clues))


def inspect_scp(session, account_id):
    out = {
        "organizations_accessible": False,
        "scp_attached": [],
        "scp_details": [],
        "region_restriction_detected": False,
        "region_restriction_clues": [],
        "errors": []
    }

    org = safe_client(session, "organizations", region_name="us-east-1")

    try:
        out["organizations_accessible"] = True

        paginator = org.get_paginator("list_policies_for_target")
        for page in paginator.paginate(TargetId=account_id, Filter="SERVICE_CONTROL_POLICY"):
            out["scp_attached"].extend(page.get("Policies", []))

        for pol in out["scp_attached"]:
            try:
                desc = org.describe_policy(PolicyId=pol["Id"])
                policy = desc.get("Policy", {})
                content = policy.get("Content", "")

                out["scp_details"].append({
                    "id": pol.get("Id"),
                    "name": pol.get("Name"),
                    "description": pol.get("Description"),
                    "content": content
                })

                detected, clues = analyze_scp_content(content)
                if detected:
                    out["region_restriction_detected"] = True
                    out["region_restriction_clues"].append({
                        "policy_name": pol.get("Name"),
                        "policy_id": pol.get("Id"),
                        "clues": clues
                    })

            except botocore.exceptions.ClientError as e:
                out["errors"].append(f"{pol.get('Name')}: {short_error(e)}")

    except botocore.exceptions.ClientError as e:
        out["errors"].append(short_error(e))

    return out


# =========================================================
# REGIONS
# =========================================================
def is_region_enabled(opt_in_status):
    return opt_in_status in {"opted-in", "opt-in-not-required", "manual"}


def get_regions(session):
    if ARGS.regions:
        return [{"RegionName": r, "OptInStatus": "manual"} for r in sorted(set(ARGS.regions))]

    ec2 = safe_client(session, "ec2", region_name="us-east-1")
    resp = ec2.describe_regions(AllRegions=True)

    all_regions = [{
        "RegionName": r.get("RegionName"),
        "OptInStatus": r.get("OptInStatus", "unknown")
    } for r in resp.get("Regions", [])]
    all_regions.sort(key=lambda x: x["RegionName"])

    if ARGS.include_disabled_regi
ons:
        return all_regions

    return [r for r in all_regions if is_region_enabled(r["OptInStatus"])]


