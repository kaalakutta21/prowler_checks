# TESTS
# =========================================================
def get_service_tests():
    fast = [
        {"service": "ec2", "method": "describe_instances", "kwargs": {"MaxResults": 5}, "action": "ec2:DescribeInstances"},
        {"service": "lambda", "method": "list_functions", "kwargs": {"MaxItems": 5}, "action": "lambda:ListFunctions"},
        {"service": "rds", "method": "describe_db_instances", "kwargs": {"MaxRecords": 20}, "action": "rds:DescribeDBInstances"},
    ]

    full = fast + [
        {"service": "dynamodb", "method": "list_tables", "kwargs": {"Limit": 10}, "action": "dynamodb:ListTables"},
        {"service": "ecs", "method": "list_clusters", "kwargs": {"maxResults": 10}, "action": "ecs:ListClusters"},
        {"service": "eks", "method": "list_clusters", "kwargs": {"maxResults": 10}, "action": "eks:ListClusters"},
    ]

    return fast if ARGS.mode == "fast" else full


SERVICE_TESTS = get_service_tests()


def run_service_test(session, region_name, test):
    client = safe_client(session, test["service"], region_name=region_name)
    method = getattr(client, test["method"])

    try:
        method(**test["kwargs"])
        return {
            "service": test["service"],
            "action": test["action"],
            "status": "ALLOWED",
            "classification": "ALLOWED",
            "error": None
        }
    except botocore.exceptions.ClientError as e:
        return {
            "service": test["service"],
            "action": test["action"],
            "status": "DENIED",
            "classification": classify_error(e),
            "error": short_error(e)
        }
    except Exception as e:
        return {
            "service": test["service"],
            "action": test["action"],
            "status": "ERROR",
            "classification": "OTHER_ERROR",
            "error": str(e)
        }


def build_region_record(region_name, opt_in_status):
    return {
        "region": region_name,
        "opt_in_status": opt_in_status,
        "is_india_region": region_name in {"ap-south-1", "ap-south-2"},
        "service_results": [],
        "summary": {
            "allowed": 0,
            "denied": 0,
            "scp_deny": 0,
            "iam_or_session_deny": 0,
            "permission_boundary_deny": 0,
            "session_policy_deny": 0,
            "region_not_enabled": 0,
            "other_error": 0
        }
    }


def check_region_service(session, region, test):
    region_name = region["RegionName"]
    res = run_service_test(session, region_name, test)
    return region_name, region["OptInStatus"], res


def audit_regions_parallel(session, regions, max_workers=10):
    results_map = {
        region["RegionName"]: build_region_record(region["RegionName"], region["OptInStatus"])
        for region in regions
    }

    total_steps = len(regions) * len(SERVICE_TESTS)
    pbar = tqdm(total=total_steps, desc="Testing access", unit="check") if tqdm else None

    futures = []
    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        for region in regions:
            for test in SERVICE_TESTS:
                futures.append(executor.submit(check_region_service, session, region, test))

        for future in as_completed(futures):
            region_name, _, res = future.result()
            record = results_map[region_name]
            record["service_results"].append(res)

            cls = res["classification"]
            if cls == "ALLOWED":
                record["summary"]["allowed"] += 1
            elif cls == "SCP_DENY":
                record["summary"]["scp_deny"] += 1
                record["summary"]["denied"] += 1
            elif cls == "IAM_OR_SESSION_DENY":
                record["summary"]["iam_or_session_deny"] += 1
                record["summary"]["denied"] += 1
            elif cls == "PERMISSION_BOUNDARY_DENY":
                record["summary"]["permission_boundary_deny"] += 1
                record["summary"]["denied"] += 1
            elif cls == "SESSION_POLICY_DENY":
                record["summary"]["session_policy_deny"] += 1
                record["summary"]["denied"] += 1
            elif cls == "REGION_NOT_ENABLED":
                record["summary"]["region_not_enabled"] += 1
            else:
                record["summary"]["other_error"] += 1
                if res["status"] != "ALLOWED":
                    record["summary"]["denied"] += 1

            if pbar:
                pbar.update(1)

    if pbar:
        pbar.close()

    results = list(results_map.values())
    for record in results:
        record["service_results"].sort(key=lambda x: x["service"])
    results.sort(key=lambda x: x["region"])
    return results


# =========================================================
# FINDINGS
# =========================================================
def derive_findings(identity, iam_info, scp_info, region_results):
    findings = {
        "outside_india_any_access": False,
        "all_tested_regions_full_read_access": True,
        "regions_with_any_access_outside_india": [],
        "regions_fully_blocked_by_scp": [],
        "regions_partially_allowed": [],
        "regions_denied_by_iam_or_session": [],
        "possible_temporary_access_clues": []
    }

    for rr in region_results:
        region = rr["region"]
        summary = rr["summary"]

        allowed = summary["allowed"]
        denied = summary["denied"]
        scp_deny = summary["scp_deny"]
        iam_related = (
            summary["iam_or_session_deny"] +
            summary["permission_boundary_deny"] +
            summary["session_policy_deny"]
        )

        if region not in {"ap-south-1", "ap-south-2"} and allowed > 0:
            findings["outside_india_any_access"] = True
            findings["regions_with_any_access_outside_india"].append(region)

        if allowed != len(SERVICE_TESTS):
            findings["all_tested_regions_full_read_access"] = False

        if scp_deny == len(SERVICE_TESTS):
            findings["regions_fully_blocked_by_scp"].append(region)

        if allowed > 0 and denied > 0:
            findings["regions_partially_allowed"].append(region)

        if iam_related > 0:
            findings["regions_denied_by_iam_or_session"].append(region)

    if scp_info["region_restriction_detected"] and findings["outside_india_any_access"]:
        findings["possible_temporary_access_clues"].append(
            "SCP appears to restrict by region, but some non-India regions still allow real API reads."
        )
        findings["possible_temporary_access_clues"].append(
            "Likely causes: NotAction in SCP, conditional exception logic, or only some actions/services are denied."
        )

    if identity["assumed_role"]:
        findings["possible_temporary_access_clues"].append(
            f"Current session is an assumed role: {identity.get('role_name')}"
        )

    if iam_info["readonlyaccess_attached"]:
        findings["possible_temporary_access_clues"].append(
            "AWS managed ReadOnlyAccess appears attached to the current user/role."
        )

    return findings


# =========================================================
# REPORTING
# =========================================================
def terminal_region_line(rr):
    s = rr["summary"]

    if s["allowed"] == len(SERVICE_TESTS):
        status = c("FULL_READ_OK", GREEN)
    elif s["allowed"] > 0 and s["denied"] > 0:
        status = c("PARTIAL_ACCESS", YELLOW)
    elif s["scp_deny"] == len(SERVICE_TESTS):
        status = c("BLOCKED_BY_SCP", RED)
    elif s["region_not_enabled"] == len(SERVICE_TESTS):
        status = c("REGION_DISABLED", MAGENTA)
    elif s["denied"] == len(SERVICE_TESTS):
        status = c("DENIED", RED)
    else:
        status = c("MIXED", YELLOW)

    india_tag = c("INDIA", CYAN) if rr["is_india_region"] else c("NON-INDIA", GRAY)

    return (
        f"{rr['region']:<15} {india_tag:<15} "
        f"Allowed={s['allowed']:<2} "
        f"SCP={s['scp_deny']:<2} "
        f"IAM={s['iam_or_session_deny'] + s['permission_boundary_deny'] + s['session_policy_deny']:<2} "
        f"Disabled={s['region_not_enabled']:<2} "
        f"Other={s['other_error']:<2} "
        f"-> {status}"
    )


