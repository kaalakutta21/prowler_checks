def safe_client(session, service, region_name=None):
    return session.client(service, region_name=region_name or ARGS.region)


def iso_now():
    return datetime.utcnow().strftime("%Y-%m-%dT%H-%M-%SZ")


def ensure_dir(path):
    os.makedirs(path, exist_ok=True)


def write_json(path, data):
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, default=str)


def write_text(path, text):
    with open(path, "w", encoding="utf-8") as f:
        f.write(text)


def classify_error(err):
    code = err.response.get("Error", {}).get("Code", "Unknown")
    msg = err.response.get("Error", {}).get("Message", "") or str(err)
    full = f"{code}: {msg}".lower()

    if "service control policy" in full or "explicit deny" in full and "service control policy" in full:
        return "SCP_DENY"
    if code in ("OptInRequired", "AuthFailure") and "not subscribed" in full:
        return "REGION_NOT_ENABLED"
    if "not authorized" in full or "accessdenied" in full or code in ("AccessDenied", "AccessDeniedException", "UnauthorizedOperation", "Client.UnauthorizedOperation"):
        if "permissions boundary" in full:
            return "PERMISSION_BOUNDARY_DENY"
        if "session policy" in full:
            return "SESSION_POLICY_DENY"
        return "IAM_OR_SESSION_DENY"
    if code in ("UnrecognizedClientException", "InvalidClientTokenId", "ExpiredToken"):
        return "CREDENTIAL_ISSUE"
    if code in ("RequestLimitExceeded", "Throttling", "ThrottlingException", "TooManyRequestsException"):
        return "THROTTLED"
    return "OTHER_ERROR"


def short_error(err):
    code = err.response.get("Error", {}).get("Code", "Unknown")
    msg = err.response.get("Error", {}).get("Message", "") or str(err)
    return f"{code}: {msg}"


def print_section(title):
    print("\n" + c("=" * 90, BLUE))
    print(c(title, BOLD + CYAN))
    print(c("=" * 90, BLUE))


def yes_no(value):
    return c("YES", GREEN) if value else c("NO", RED)


# =========================================================
# IDENTITY
# =========================================================
def get_identity(session):
    sts = safe_client(session, "sts")
    resp = sts.get_caller_identity()
    arn = resp.get("Arn", "")
    account = resp.get("Account", "")
    user_id = resp.get("UserId", "")

    identity = {
        "account_id": account,
        "arn": arn,
        "user_id": user_id,
        "principal_type": "unknown",
        "assumed_role": False,
        "role_name": None,
        "user_name": None,
        "session_name": None
    }

    if ":assumed-role/" in arn:
        identity["principal_type"] = "assumed-role"
        identity["assumed_role"] = True
        m = re.search(r"assumed-role/([^/]+)/(.+)$", arn)
        if m:
            identity["role_name"] = m.group(1)
            identity["session_name"] = m.group(2)
    elif ":user/" in arn:
        identity["principal_type"] = "user"
        identity["user_name"] = arn.split("/")[-1]
    elif ":role/" in arn:
        identity["principal_type"] = "role"
        identity["role_name"] = arn.split("/")[-1]

    return identity


# =========================================================
# IAM VISIBILITY
# =========================================================
def inspect_iam(session, identity):
    out = {
        "visibility": True,
        "managed_policies": [],
        "inline_policies": [],
        "permission_boundary": None,
        "readonlyaccess_attached": False,
        "errors": []
    }

    iam = safe_client(session, "iam")

    try:
        if identity["principal_type"] == "user" and identity["user_name"]:
            uname = identity["user_name"]

            up = iam.get_user(UserName=uname)["User"]
            out["permission_boundary"] = up.get("PermissionsBoundary")

            paginator = iam.get_paginator("list_attached_user_policies")
            for page in paginator.paginate(UserName=uname):
                for p in page.get("AttachedPolicies", []):
                    out["managed_policies"].append(p)

            paginator = iam.get_paginator("list_user_policies")
            for page in paginator.paginate(UserName=uname):
                for p in page.get("PolicyNames", []):
                    out["inline_policies"].append(p)

        elif identity["role_name"]:
            rname = identity["role_name"]

            role = iam.get_role(RoleName=rname)["Role"]
            out["permission_boundary"] = role.get("PermissionsBoundary")

            paginator = iam.get_paginator("list_attached_role_policies")
            for page in paginator.paginate(RoleName=rname):
                for p in page.get("AttachedPolicies", []):
                    out["managed_policies"].append(p)

            paginator = iam.get_paginator("list_role_policies")
            for page in paginator.paginate(RoleName=rname):
                for p in page.get("PolicyNames", []):
                    out["inline_policies"].append(p)

        for p in out["managed_policies"]:
            if p.get("PolicyName") == "ReadOnlyAccess" or p.get("PolicyArn", "").endswith(":policy/ReadOnlyAccess"):
                out["readonlyaccess_attached"] = True

    except botocore.exceptions.ClientError as e:
        out["visibility"] = False
        out["errors"].append(short_error(e))

    return out


# =========================================================
# ORG / SCP VISIBILITY
# =========================================================
def inspect_scp(session, account_id):
    result = {
        "organizations_accessible": False,
        "scp_attached": [],
        "scp_details": [],
        "region_restriction_detected": False,
        "region_restriction_clues": [],
        "errors": []
    }

    org = safe_client(session, "organizations", region_name="us-east-1")

    try:
        result["organizations_accessible"] = True

        paginator = org.get_paginator("list_policies_for_target")
        for page in paginator.paginate(TargetId=account_id, Filter="SERVICE_CONTROL_POLICY"):
            for pol in page.get("Policies", []):
                result["scp_attached"].append(pol)

        for pol in result["scp_attached"]:
            try:
                d = org.describe_policy(PolicyId=pol["Id"])
                policy = d.get("Policy", {})
                content = policy.get("Content", "")
                record = {
                    "id": pol.get("Id"),
                    "name": pol.get("Name"),
                    "description": pol.get("Description"),
                    "content": content
                }
                result["scp_details"].append(record)

                detected, clues = analyze_scp_content(content)
                if detected:
                    result["region_restriction_detected"] = True
                    result["region_restriction_clues"].append({
                        "policy_name": pol.get("Name"),
                        "policy_id": pol.get("Id"),
                        "clues": clues
                    })

            except botocore.exceptions.ClientError as e:
                result["errors"].append(f"{pol.get('Name')}: {short_error(e)}")

    except botocore.exceptions.ClientError as e:
        result["errors"].append(short_error(e))

    return result


def analyze_scp_content(content):
    detected = False
    clues = []

    try:
        if isinstance(content, str):
            doc = json.loads(content)
        else:
            doc = content

        statements = doc.get("Statement", [])
        if isinstance(statements, dict):
            statements = [statements]

        for stmt in statements:
            cond = stmt.get("Condition", {})
            stmt_text = json.dumps(stmt).lower()

            if "aws:requestedregion" in stmt_text:
                detected = True
                clues.append("Contains aws:RequestedRegion condition")

            if stmt.get("Effect") == "Deny":
                clues.append("Contains Deny statement")

            if "notaction" in stmt_text:
                clues.append("Uses NotAction (possible exceptions/bypass for some services)")

            if "arnnotlike" in stmt_text or "stringnotequals" in stmt_text:
                clues.append("Contains exception-style condition (ArnNotLike/StringNotEquals)")

    except Exception as e:
        clues.append(f"Failed to parse SCP JSON content: {e}")

    return detected, list(dict.fromkeys(clues))


# =========================================================
# REGIONS
# =========================================================
def get_all_regions(session):
    ec2 = safe_client(session, "ec2", region_name="us-east-1")
    resp = ec2.describe_regions(AllRegions=True)
    regions = []
    for r in resp.get("Regions", []):
        regions.append({
            "RegionName": r.get("RegionName"),
            "OptInStatus": r.get("OptInStatus", "unknown")
        })
    regions.sort(key=lambda x: x["RegionName"])
    return regions


# =========================================================
# SERVICE TESTS
# =========================================================
SERVICE_TESTS = [
    {"service": "ec2", "method": "describe_instances", "kwargs": {"MaxResults": 5}, "action": "ec2:DescribeInstances"},
    {"service": "lambda", "method": "list_functions", "kwargs": {"MaxItems": 5}, "action": "lambda:ListFunctions"},
    {"service": "rds", "method": "describe_db_instances", "kwargs": {"MaxRecords": 20}, "action": "rds:DescribeDBInstances"},
    {"service": "dynamodb", "method": "list_tables", "kwargs": {"Limit": 10}, "action": "dynamodb:ListTables"},
    {"service": "ecs", "method": "list_clusters", "kwargs": {"maxResults": 10}, "action": "ecs:ListClusters"},
    {"service": "eks", "method": "list_clusters", "kwargs": {"maxResults": 10}, "action": "eks:ListClusters"},
]


def run_service_test(session, region_name, test):
    service = test["service"]
    method_name = test["method"]
    kwargs = test["kwargs"]
    action = test["action"]

    client = safe_client(session, service, region_name=region_name)
    method = getattr(client, method_name)

    try:
        method(**kwargs)
        return {
            "service": service,
            "action": action,
            "status": "ALLOWED",
            "classification": "ALLOWED",
            "error": None
        }
    except botocore.exceptions.ClientError as e:
        return {
            "service": service,
            "action": action,
            "status": "DENIED",
            "classification": classify_error(e),
            "error": short_error(e)
        }
    except Exception as e:
        return {
            "service": service,
            "action": action,
            "status": "ERROR",
            "classification": "OTHER_ERROR",
            "error": str(e)
        }


# =========================================================
# AUDIT
# =========================================================
def audit_regions(session, regions):
    results = []
    total_steps = len(regions) * len(SERVICE_TESTS)

    iterator = regions
    if tqdm:
        iterator = tqdm(total=total_steps, desc="Testing region/service access", unit="check")

    for region in regions:
        rname = region["RegionName"]
        opt_in = region["OptInStatus"]

        region_record = {
            "region": rname,
            "opt_in_status": opt_in,
            "is_india_region": rname in {"ap-south-1", "ap-south-2"},
            "service_results": [],
            "summary": {
                "allowed": 0,
                "denied": 0,
                "scp_deny": 0,
                "iam_or_session_deny": 0,
                "permission_boundary_deny": 0,
                "session_policy_deny": 0,
                "region_not_enabled": 0,
                "other_error": 0
            }
        }

        for test in SERVICE_TESTS:
            res = run_service_test(session, rname, test)
            region_record["service_results"].append(res)

            cls = res["classification"]
            if cls == "ALLOWED":
                region_record["summary"]["allowed"] += 1
            elif cls == "SCP_DENY":
                region_record["summary"]["scp_deny"] += 1
                region_record["summary"]["denied"] += 1
            elif cls == "IAM_OR_SESSION_DENY":
                region_record["summary"]["iam_or_session_deny"] += 1
                region_record["summary"]["denied"] += 1
            elif cls == "PERMISSION_BOUNDARY_DENY":
                region_record["summary"]["permission_boundary_deny"] += 1
                region_record["summary"]["denied"] += 1
            elif cls == "SESSION_POLICY_DENY":
                region_record["summary"]["session_policy_deny"] += 1
                region_record["summary"]["denied"] += 1
            elif cls == "REGION_NOT_ENABLED":
                region_record["summary"]["region_not_enabled"] += 1
            else:
                region_record["summary"]["other_error"] += 1
                if res["status"] != "ALLOWED":
                    region_record["summary"]["denied"] += 1

            if tqdm:
                iterator.update(1)

        results.append(region_record)

    if tqdm:
        iterator.close()

    return results


# =========================================================
# ANALYSIS
# =========================================================
def derive_findings(identity, iam_info, scp_info, region_results):
    findings = {
        "outside_india_any_access": False,
        "all_regions_full_read_access": True,
        "regions_with_any_access_outside_india": [],
        "regions_fully_blocked_by_scp": [],
        "regions_partially_allowed": [],
        "regions_denied_by_iam_or_session": [],
        "possible_temporary_access_clues": []
    }

    for rr in region_results:
        region = rr["region"]
        allowed = rr["summary"]["allowed"]
        denied = rr["summary"]["denied"]
        scp_deny = rr["summary"]["scp_deny"]
        iam_deny = (
            rr["summary"]["iam_or_session_deny"] +
            rr["summary"]["permission_boundary_deny"] +
            rr["summary"]["session_policy_deny"]
        )

        if region not in {"ap-south-1", "ap-south-2"} and allowed > 0:
            findings["outside_india_any_access"] = True
            findings["regions_with_any_access_outside_india"].append(region)

        if allowed != len(SERVICE_TESTS):
            findings["all_regions_full_read_access"] = False

        if scp_deny == len(SERVICE_TESTS):
            findings["regions_fully_blocked_by_scp"].append(region)

        if allowed > 0 and denied > 0:
            findings["regions_partially_allowed"].append(region)

        if iam_deny > 0:
            findings["regions_denied_by_iam_or_session"].append(region)

    # Heuristic clues
    if scp_info["region_restriction_detected"] and findings["outside_india_any_access"]:
        findings["possible_temporary_access_clues"].append(
            "SCP appears to contain region restriction logic, but real API access still works in one or more non-India regions."
        )
        findings["possible_temporary_access_clues"].append(
            "Likely explanation: SCP uses NotAction or exception conditions, or temporary access is coming from allowed read/list actions that SCP does not block."
        )

    if iam_info["readonlyaccess_attached"]:
        findings["possible_temporary_access_clues"].append(
            "ReadOnlyAccess appears attached/visible on the current principal."
        )

    if identity["assumed_role"]:
        findings["possible_temporary_access_clues"].append(
            f"Session is an assumed role session: {identity.get('role_name')}. Temporary access may be granted through this role."
        )

    return findings


# =========================================================
# REPORT FORMATTING
# =========================================================
def terminal_region_line(rr):
    region = rr["region"]
    summ = rr["summary"]

    if summ["allowed"] == len(SERVICE_TESTS):
        status = c("FULL_READ_OK", GREEN)
    elif summ["allowed"] > 0 and summ["denied"] > 0:
        status = c("PARTIAL_ACCESS", YELLOW)
    elif summ["scp_deny"] == len(SERVICE_TESTS):
        status = c("BLOCKED_BY_SCP", RED)
    elif summ["region_not_enabled"] == len(SERVICE_TESTS):
        status = c("REGION_NOT_ENABLED", MAGENTA)
    elif summ["denied"] == len(SERVICE_TESTS):
        status = c("DENIED", RED)
    else:
        status = c("MIXED/UNKNOWN", YELLOW)

    india_tag = c("INDIA", CYAN) if rr["is_india_region"] else c("NON-INDIA", GRAY)

    return (
        f"{region:<15} {india_tag:<18} "
        f"Allowed={summ['allowed']:<2} "
        f"SCP={summ['scp_deny']:<2} "
        f"IAM/Session={summ['iam_or_session_deny'] + summ['permission_boundary_deny'] + summ['session_policy_deny']:<2} "
        f"RegionDisabled={summ['region_not_enabled']:<2} "
        f"Other={summ['other_error']:<2} "
        f"-> {status}"
    )


