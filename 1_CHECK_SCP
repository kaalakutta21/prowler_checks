def parse_args():
    parser = argparse.ArgumentParser(
        description="Audit AWS effective cross-region read-only access, SCP visibility, and IAM clues."
    )
    parser.add_argument(
        "-R", "--role-arn",
        help="Optional role ARN to assume before running checks."
    )
    parser.add_argument(
        "--external-id",
        help="Optional external ID for assume-role."
    )
    parser.add_argument(
        "--profile",
        help="Optional AWS profile name."
    )
    parser.add_argument(
        "--region",
        default="ap-south-1",
        help="Base region for global/control-plane calls. Default: ap-south-1"
    )
    parser.add_argument(
        "--outdir",
        default="region_access_audit_output",
        help="Directory to store output files."
    )
    parser.add_argument(
        "--no-color",
        action="store_true",
        help="Disable terminal colors."
    )
    parser.add_argument(
        "--timeout-note",
        action="store_true",
        help="Print extra explanatory notes in terminal."
    )
